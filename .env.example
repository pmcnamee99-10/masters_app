# ── API Provider ──────────────────────────────────────────────────────────────
# Controls where live scores come from.
# Leave unset (or delete this file) to use mock data during development.
#
# 'espn'  → ESPN unofficial API. Free, no key needed, works from the browser.
#            Best option for most cases. Set VITE_API_PROVIDER=espn and nothing else.
#
# 'api'   → Vercel serverless proxy (/api/scores). Used for paid APIs (SportsRadar,
#            API-Sports). Set SCORES_API_PROVIDER and SCORES_API_KEY below too.

VITE_API_PROVIDER=espn

# ── Refresh interval ──────────────────────────────────────────────────────────
# How often the app polls for updated scores, in milliseconds.
# Default: 180000 (3 minutes). During active rounds you may want 60000 (1 min).

VITE_REFRESH_INTERVAL=180000

# ── Paid API config (server-side only — NOT VITE_ prefix) ─────────────────────
# Only needed if VITE_API_PROVIDER=api.
# Set these in Vercel dashboard → Project → Settings → Environment Variables.
# Do NOT put these in .env.local — they should never reach the browser.
#
# Supported providers:
#   sportradar  → https://developer.sportradar.com/golf  (~$150/month, trial free)
#   apisports   → https://rapidapi.com/api-sports/api/golf-leaderboards  (~$10/month)

SCORES_API_PROVIDER=sportradar
SCORES_API_KEY=your_api_key_here
